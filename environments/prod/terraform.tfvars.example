subscription_id     = "a8270be7-dabc-4d92-98db-26a55025b0df"
hub_subscription_id = "5b942f88-17e6-4026-ae23-d520365fb916"
tenant_id           = "83474cb5-f1fa-4d06-906c-e5dad12ce3b9"
location            = "centralindia"
environment         = "prod"
vnet_cidr           = "10.30.0.0/16"

hub_state_resource_group_name  = "rg-kairoai-tfstate-ci"
hub_state_storage_account_name = "stkairoaitfstateci"
hub_state_container_name       = "hubtfstate"
hub_state_key                  = "kairoai/hub/terraform.tfstate"

log_retention_days            = 90
alert_email                   = ""
public_network_access_enabled = true

postgres_version    = "16"
postgres_sku_name   = "GP_Standard_D2s_v3"
postgres_storage_mb = 131072
service_bus_sku                          = "Premium"
service_bus_capacity                     = 1
service_bus_premium_messaging_partitions = 1

aks_private_cluster_enabled = true
aks_system_node_vm_size     = "Standard_D2s_v4"
aks_system_node_min_count   = 2
aks_system_node_max_count   = 3
aks_user_node_vm_size       = "Standard_D2s_v4"
aks_user_node_min_count     = 2
aks_user_node_max_count     = 6
aks_cluster_admin_principal_ids = ["351af7b8-31dd-4186-a7bc-c2f38a79d242"]

# Production runtime lives in this spoke. Shared edge routing is owned by the hub environment.
enable_aks             = true
enable_app_gateway_waf = true
enable_ai_foundry      = true

app_gateway_min_capacity = 1
app_gateway_max_capacity = 3
ai_foundry_sku_name      = "S0"
ai_foundry_name          = "oai-kairoai-prod-si"
ai_foundry_location      = "southindia"
ai_foundry_deployments = {
  "gpt-5.4" = {
    model_name    = "gpt-5.4"
    model_version = "2026-03-05"
    sku_name      = "GlobalStandard"
    capacity      = 10
  }
  "gpt-5.4-mini" = {
    model_name    = "gpt-5.4-mini"
    model_version = "2026-03-17"
    sku_name      = "GlobalStandard"
    capacity      = 10
  }
}
managed_identities       = {}
policy_assignments       = {}

key_vault_purge_protection_enabled   = true
key_vault_soft_delete_retention_days = 90

tags = {
  application = "kairoai"
  environment = "prod"
  managed_by  = "terraform"
}
